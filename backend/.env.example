# Swachh Vayu Backend - Production Environment Variables
# Rename this file to .env on the Raspberry Pi

# Security
SECRET_KEY=generate_a_secure_random_string_here
JWT_SECRET_KEY=generate_another_secure_random_string_here

# Database
DATABASE_NAME=swachh_vayu.db

# Flask Environment
FLASK_APP=app.py
FLASK_ENV=production
DEBUG_MODE=False

# Hardware Ports (Linux/Raspberry Pi Paths)
LORA_SERIAL_PORT=/dev/ttyUSB0
LORA_BAUD_RATE=9600

GSM_SERIAL_PORT=/dev/ttyS0
GSM_BAUD_RATE=9600
GSM_MOCK_MODE=False

# Application Logic
ALERT_COOLDOWN_SECONDS=900

# Future Integrations
SARVAM_API_KEY=your_sarvam_api_key_here
